# Firebase (client)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MONTHLY_RON=
STRIPE_PRICE_PREMIUM_ANNUAL_RON=
STRIPE_PRICE_REPORT_ONEOFF_RON=
# Optional legacy fallback prices
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_COSMIC_PLUS_MONTHLY=

# Oblio
OBLIO_BASE_URL=https://www.oblio.eu
OBLIO_CLIENT_ID=
OBLIO_CLIENT_SECRET=
OBLIO_CIF=
# Preferred key
OBLIO_SERIES_NAME=
# Backward compatibility fallback (optional if OBLIO_SERIES_NAME is set)
OBLIO_SERIES=
OBLIO_DEFAULT_LANGUAGE=RO
OBLIO_DEFAULT_CURRENCY=RON
OBLIO_SEND_EMAIL=1
OBLIO_RETRY_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Divine API
DIVINE_API_KEY=
DIVINE_API_AUTH_MODE=bearer
DIVINE_HOROSCOPE_BASE_URL=https://astroapi-5.divineapi.com
DIVINE_HOROSCOPE_DAILY_PATH=/api/v5/daily-horoscope
DIVINE_API_LANGUAGE=en
DIVINE_API_DEFAULT_TZONE=2
DIVINE_API_DEFAULT_HOUSE_SYSTEM=P
DIVINE_API_DEFAULT_ZODIAC=tropical
DIVINE_WESTERN_BASE_URL=https://astroapi-4.divineapi.com
DIVINE_WESTERN_CHART_BASE_URL=https://astroapi-8.divineapi.com
DIVINE_NATAL_PLANETARY_POSITIONS_PATH=/western-api/v1/planetary-positions
DIVINE_NATAL_HOUSE_CUSPS_PATH=/western-api/v1/house-cusps
DIVINE_NATAL_ASPECT_TABLE_PATH=/western-api/v2/aspect-table
DIVINE_NATAL_WHEEL_CHART_PATH=/western-api/v2/natal-wheel-chart
DIVINE_SYNASTRY_PLANETARY_POSITIONS_PATH=/western-api/v1/synastry/planetary-positions
DIVINE_SYNASTRY_ASPECT_TABLE_PATH=/western-api/v2/synastry/aspect-table
DIVINE_SYNASTRY_WHEEL_CHART_PATH=/western-api/v2/synastry/natal-wheel-chart

# Google Maps / Places (server-side location resolver)
GOOGLE_MAPS_API_KEY=
# Optional endpoint overrides
GOOGLE_PLACES_AUTOCOMPLETE_URL=https://maps.googleapis.com/maps/api/place/autocomplete/json
GOOGLE_PLACES_DETAILS_URL=https://maps.googleapis.com/maps/api/place/details/json
GOOGLE_GEOCODE_URL=https://maps.googleapis.com/maps/api/geocode/json
GOOGLE_TIMEZONE_URL=https://maps.googleapis.com/maps/api/timezone/json
